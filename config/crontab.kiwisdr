20 14 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_satellite_12z 660
45 14 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_500mb_12z 600
5 15 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_surface_12z 720
22 18 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_24hr_wind_wave_12z 600
45 18 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_sst 660
40 20 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_48hr_surface_12z 600
24 21 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_surface_18z 720

