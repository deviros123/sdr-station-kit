# --- NAVTEX (518 kHz, every 4 hours) ---
0 0 * * * /home/dragon/kiwi-navtex-monitor.sh 600
10 4 * * * /home/dragon/kiwi-navtex-monitor.sh 600
40 8 * * * /home/dragon/kiwi-navtex-monitor.sh 600
10 12 * * * /home/dragon/kiwi-navtex-monitor.sh 600
10 16 * * * /home/dragon/kiwi-navtex-monitor.sh 600
20 20 * * * /home/dragon/kiwi-navtex-monitor.sh 600

# --- EAS Alerts (RTL-SDR, unchanged) ---
5,35 * * * * /home/dragon/weather-monitor.sh eas 162550000 120

# --- Dashboard regeneration ---
*/15 * * * * /home/dragon/weather-dashboard.py 2>/dev/null

# --- Watchdog ---
*/5 * * * * /home/dragon/sdr-watchdog.sh

# --- Weekly full-band scan (Saturday 23:00 UTC) ---
0 23 * * 6 /home/dragon/sdr-weekly-scan.sh
