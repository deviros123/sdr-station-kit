30 2 * * * /home/dragon/kiwi-fax-capture.sh 4346 ptreyes_500mb_00z 600
0 3 * * * /home/dragon/kiwi-fax-capture.sh 4346 ptreyes_sea_state_00z 600
31 3 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_surface_00z 720
20 8 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_24hr_wind_wave 600
0 9 * * * /home/dragon/kiwi-fax-capture.sh 8682 ptreyes_48hr_surface 600
